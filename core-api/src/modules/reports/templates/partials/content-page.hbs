        <div class="w-8 h-8 bg-slate-800 rounded flex items-center justify-center">
          <span class="text-white font-bold text-sm">{{systemNameChar}}</span>
        </div>
        <div>
          <h1 class="text-xl font-bold text-slate-900 m-0">{{reportTitle}}</h1>
        </div>
