<header class="flex items-center justify-between py-3 mb-4" style="border-bottom: 1px solid #e2e8f0;">
  <div class="flex items-center gap-3">
    {{#if logoBase64}}
      <img src="{{logoBase64}}" alt="Logo" style="height: 32px; width: auto;" />
    {{else}}
      <div style="width: 32px; height: 32px; background: #dc2626; border-radius: 6px; display: flex; align-items: center; justify-content: center;">
        <span style="color: white; font-weight: bold; font-size: 14px;">O</span>
      </div>
    {{/if}}
  </div>
  <div class="flex flex-col items-end gap-0.5" style="font-size: 9px; color: #64748b;">
    <div class="flex items-center gap-1.5">
      <span style="color: #dc2626;">&#9679;</span>
      <span>https://cyberjutsu.io</span>
    </div>
    <div class="flex items-center gap-1.5">
      <span style="color: #dc2626;">&#9993;</span>
      <span>contact@cyberjutsu.io</span>
    </div>
    <div class="flex items-center gap-1.5">
      <span style="color: #dc2626;">&#9742;</span>
      <span>+(84) 277 137118</span>
    </div>
  </div>
</header>
