<header class="border-b border-slate-200 pb-5 mb-6">
  <div class="flex items-start justify-between">
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 bg-slate-900 rounded-lg flex items-center justify-center">
        <span class="text-white font-bold text-xs tracking-wide">{{systemNameChar}}</span>
      </div>
      <div>
        <h1 class="text-lg font-bold tracking-tight text-slate-900 m-0">{{reportTitle}}</h1>
        <p class="text-[11px] text-slate-400 m-0 mt-0.5">Week {{week}}, {{year}} · Exported {{formattedDate}}</p>
      </div>
    </div>
    <div class="text-right">
      <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded text-[10px] font-semibold uppercase tracking-wider bg-red-50 text-red-700 border border-red-200">
        <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
        {{classification}}
      </span>
    </div>
  </div>
</header>
