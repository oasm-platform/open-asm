<div style="height: 297mm; page-break-after: always;" class="flex flex-col bg-white">
  <!-- Top accent bar -->
  <div class="h-1.5 bg-gradient-to-r from-slate-800 via-slate-600 to-slate-400"></div>

  <!-- Header section -->
  <div class="px-12 pt-10">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-slate-900 rounded-lg flex items-center justify-center shadow-lg">
          <span class="text-white font-bold text-sm tracking-wide">{{systemNameChar}}</span>
        </div>
        <div>
          <span class="text-xs font-semibold text-slate-500 uppercase tracking-[0.25em] block">OASM Platform</span>
          <span class="text-[10px] text-slate-400 tracking-wider">Security Intelligence</span>
        </div>
      </div>
      <div class="text-right">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md text-[10px] font-semibold uppercase tracking-wider bg-red-50 text-red-700 border border-red-200">
          <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
          {{classification}}
        </span>
      </div>
    </div>
  </div>

  <!-- Main content area -->
  <div class="flex-1 flex flex-col justify-center px-12">
    <div class="max-w-2xl">
      <!-- Report type label -->
      <div class="mb-6">
        <span class="text-[11px] font-medium text-slate-400 uppercase tracking-[0.3em]">Security Assessment</span>
        <div class="mt-2 w-12 h-0.5 bg-slate-800"></div>
      </div>

      <!-- Main title -->
      <h1 class="text-[52px] font-bold text-slate-900 leading-[1.1] tracking-tight mb-6" style="letter-spacing: -0.02em;">
        Vulnerability<br/>Assessment Report
      </h1>

      <!-- Description -->
      <p class="text-base text-slate-500 leading-relaxed mb-10 max-w-lg">
        Comprehensive vulnerability analysis of your attack surface, including severity distribution, critical findings, and remediation recommendations.
      </p>

      <!-- Metadata grid -->
      <div class="grid grid-cols-2 gap-x-16 gap-y-5">
        <div class="group">
          <span class="text-[10px] font-medium text-slate-400 uppercase tracking-wider block mb-1">Reporting Period</span>
          <p class="text-sm font-semibold text-slate-800">Week {{week}}, {{year}}</p>
        </div>
        <div class="group">
          <span class="text-[10px] font-medium text-slate-400 uppercase tracking-wider block mb-1">Classification</span>
          <p class="text-sm font-semibold text-red-600">{{classification}}</p>
        </div>
        <div class="group">
          <span class="text-[10px] font-medium text-slate-400 uppercase tracking-wider block mb-1">Date Generated</span>
          <p class="text-sm font-semibold text-slate-800">{{formattedDate}}</p>
        </div>
        <div class="group">
          <span class="text-[10px] font-medium text-slate-400 uppercase tracking-wider block mb-1">Document Reference</span>
          <p class="text-sm font-semibold text-slate-800 font-mono">OASM-VUL-{{year}}-{{weekPad}}-001</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom section -->
  <div class="px-12 pb-10">
    <!-- Divider -->
    <div class="border-t border-slate-200 pt-6">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-6">
          <div class="flex items-center gap-2">
            <div class="w-6 h-6 bg-slate-100 rounded flex items-center justify-center">
              <span class="text-slate-600 text-[10px] font-bold">{{systemNameChar}}</span>
            </div>
            <span class="text-xs font-medium text-slate-600">{{systemName}}</span>
          </div>
          <span class="text-slate-300">|</span>
          <span class="text-[10px] text-slate-400">Confidential - Internal Use Only</span>
        </div>
        <div class="text-right">
          <span class="text-[10px] text-slate-400">© 2026 {{systemName}}. All Rights Reserved.</span>
        </div>
      </div>
    </div>
  </div>
</div>
