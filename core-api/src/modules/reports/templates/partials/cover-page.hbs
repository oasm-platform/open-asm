<div style="height: 297mm; page-break-after: always;" class="flex flex-col border-b border-slate-300">
  <div class="shrink-0 p-3">
    <div class="h-2 bg-slate-800"></div>
    <div class="px-10 py-8">
      <div class="flex items-center gap-3">
        <div class="w-7 h-7 bg-slate-800 rounded flex items-center justify-center">
          <span class="text-white text-xs font-bold">{{systemNameChar}}</span>
        </div>
        <span class="text-sm font-semibold text-slate-700 uppercase tracking-widest">{{systemName}}</span>
      </div>
    </div>
  </div>

  <div class="flex-1 flex flex-col justify-center px-10">
    <div class="space-y-12">
      <div class="space-y-2">
        <p class="text-sm text-slate-500 uppercase tracking-[0.2em] font-medium m-0">Security Assessment Report</p>
        <div class="w-16 h-0.5 bg-slate-800"></div>
      </div>

      <div class="space-y-4">
        <h1 class="text-5xl font-bold text-slate-900 leading-tight m-0 mb-4">
          Attack Surface<br>Discovery Report
        </h1>
        <p class="text-lg text-slate-500 max-w-xl leading-relaxed m-0">
          Comprehensive security analysis of your external attack surface,
          including vulnerability assessment, asset discovery, and risk
          evaluation.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-x-12 gap-y-3 max-w-lg">
        <div>
          <p class="text-[10px] text-slate-400 uppercase tracking-wider m-0 mb-0.5">Period</p>
          <p class="text-sm font-medium text-slate-800 m-0">Week {{week}}, {{year}}</p>
        </div>
        <div>
          <p class="text-[10px] text-slate-400 uppercase tracking-wider m-0 mb-0.5">Classification</p>
          <p class="text-sm font-medium text-red-600 m-0">{{classification}}</p>
        </div>
        <div>
          <p class="text-[10px] text-slate-400 uppercase tracking-wider m-0 mb-0.5">Date Exported</p>
          <p class="text-sm font-medium text-slate-800 m-0">{{exportedAt}}</p>
        </div>
        <div>
          <p class="text-[10px] text-slate-400 uppercase tracking-wider m-0 mb-0.5">Document Ref</p>
          <p class="text-sm font-medium text-slate-800 font-mono m-0">OASM-RPT-{{year}}-{{weekPad}}-001</p>
        </div>
      </div>
    </div>
  </div>

  <div class="shrink-0 border-t border-slate-200 px-10 py-6">
    <div class="flex justify-between text-xs text-slate-400">
      <p class="m-0">© 2026 {{systemName}}. All Rights Reserved.</p>
      <p class="text-red-500 font-medium m-0">{{classification}}</p>
    </div>
  </div>
</div>