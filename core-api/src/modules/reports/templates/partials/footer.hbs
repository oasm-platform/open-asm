<footer class="border-t border-slate-200 pt-5 mt-8">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-2">
        <div class="w-5 h-5 bg-slate-100 rounded flex items-center justify-center">
          <span class="text-slate-600 text-[8px] font-bold">{{systemNameChar}}</span>
        </div>
        <span class="text-[10px] font-medium text-slate-500">{{systemName}}</span>
      </div>
      <span class="text-slate-300">·</span>
      <span class="text-[10px] text-slate-400">Confidential</span>
    </div>
    <div class="flex items-center gap-4">
      <span class="text-[10px] text-slate-400">Generated {{formattedDate}}</span>
      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-[9px] font-medium bg-red-50 text-red-600 border border-red-100">
        <span class="w-1 h-1 rounded-full bg-red-500"></span>
        {{classification}}
      </span>
    </div>
  </div>
</footer>
