<div class='p-2 mb-3' style='border: 1px solid #e2e8f0;'>
  <h3 class='text-xs font-semibold text-slate-700 mb-2'>Severity Distribution</h3>
  <div class='flex items-center gap-4 mb-2'>
    {{#each severityDistribution}}
    <div class='flex items-center gap-1.5'>
      <div class='w-2 h-2 rounded-full dot-{{toLowerCase this.level}}'></div>
      <span class='text-[10px] font-medium text-slate-700'>{{this.level}}</span>
      <span class='text-[10px] text-slate-500'>({{this.count}})</span>
    </div>
    {{/each}}
  </div>
  <div class='flex h-2 rounded-full overflow-hidden bg-slate-200'>
    {{#each severityDistribution}}
    <div class='bar-{{toLowerCase this.level}}' style='width: {{this.percent}}%'></div>
    {{/each}}
  </div>
</div>