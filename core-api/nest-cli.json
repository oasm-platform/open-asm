{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "builder": {
      "type": "swc",
      "options": {
        "swcrcPath": ".swcrc",
        "extensions": [".ts", ".tsx", ".js", ".jsx"]
      }
    },
    "typeCheck": true,
    "deleteOutDir": true,
    "assets": [
      "**/*.json",
      "**/*.yaml",
      "**/*.yml",
      "**/*.proto",
      "**/*.md",
      "**/*.ttf",
      "src/modules/agents/skills/**/*.md"
    ]
  }
}
